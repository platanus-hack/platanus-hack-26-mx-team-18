# Copia este archivo como ".env.local" y rellena los valores reales.
# Los encuentras en Supabase: Project Settings > API
#
# NEXT_PUBLIC_ = visible en el navegador (la anon key es pública, RLS protege los datos).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SECRETA: solo para scripts de servidor (ej. el scraper). NUNCA va al navegador
# ni se sube a git. Salta el RLS para poder ESCRIBIR datos. (Project Settings > API > service_role)
SUPABASE_SERVICE_ROLE_KEY=

# Búsqueda en la web con Firecrawl (scrape:firecrawl, scrape:x). Consíguela en https://firecrawl.dev
FIRECRAWL_API_KEY=
