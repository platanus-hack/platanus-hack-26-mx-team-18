#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../node_modules/pnpm/bin/pnpm.cjs" "$@"
else
  exec node  "$basedir/../node_modules/pnpm/bin/pnpm.cjs" "$@"
fi
# cmd-shim-target=/home/aryacat/platanus-hack-26-mx-team-18/.pnpm-store/v11/links/@/pnpm/10.17.0/bd07414d1b2a1a0b0e99285f8facb4a044497c587464cba23ed7244af0c374f2/node_modules/pnpm/bin/pnpm.cjs
